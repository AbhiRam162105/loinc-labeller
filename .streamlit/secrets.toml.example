# Copy this to .streamlit/secrets.toml for local runs, or paste the same content
# into Streamlit Community Cloud → App → Settings → Secrets.
#
# 1. Create a Google Cloud service account, enable the Google Sheets API + Drive
#    API, and download its JSON key.
# 2. Create a Google Sheet, then SHARE it (Editor) with the service account's
#    client_email below.
# 3. Fill in the values from the JSON key, and set gsheet_url to your sheet.

gsheet_url = "https://docs.google.com/spreadsheets/d/XXXXXXXXXXXXXXXXXXXX/edit"

[gcp_service_account]
type = "service_account"
project_id = "your-project-id"
private_key_id = "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
private_key = "-----BEGIN PRIVATE KEY-----\nMIIE...REPLACE_WITH_ESCAPED_KEY...\n-----END PRIVATE KEY-----\n"
client_email = "labeller-bot@your-project-id.iam.gserviceaccount.com"
client_id = "000000000000000000000"
auth_uri = "https://accounts.google.com/o/oauth2/auth"
token_uri = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url = "https://www.googleapis.com/robot/v1/metadata/x509/labeller-bot%40your-project-id.iam.gserviceaccount.com"
